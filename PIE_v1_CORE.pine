// PIE-v1 CORE | 2-Phase Inducement Engine — Modules M1–M7
// Absolute Dollar Intelligence (ADI) | Emmanuel, Nairobi EAT/UTC+3
// Based on: VectorFX 2-Phase Inducement Trap Theorem
//@version=6
indicator("PIE-v1 CORE | 2-Phase Inducement Engine", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════
//  SHARED INPUTS
// ═══════════════════════════════════════════════════════════════
grp_risk   = "Risk Management"
i_risk_usd = input.float(50.0, "Dollar Risk per Trade ($)", minval=1.0, group=grp_risk)
i_max_ep   = input.int(500, "KNN Max Episodes", minval=50, maxval=2000, group=grp_risk)

grp_sess   = "Session Settings"
i_show_sess = input.bool(true, "Show Session Boxes", group=grp_sess)
i_show_mmm  = input.bool(true, "Show MMM Windows", group=grp_sess)

grp_str    = "Structure"
i_swing_len = input.int(10, "Swing Lookback (bars)", minval=5, maxval=50, group=grp_str)
i_ob_len    = input.int(20, "OB Lookback (bars)",    minval=10, maxval=100, group=grp_str)

grp_htf    = "HTF Bias"
i_htf      = input.timeframe("240", "HTF Reference", group=grp_htf)
i_bias     = input.string("Auto", "Manual Bias Override", options=["Auto","Bullish","Bearish","Ranging"], group=grp_htf)

grp_col    = "ADI Colors"
c_bull     = input.color(color.new(#00e676, 0),   "Bullish",     group=grp_col)
c_bear     = input.color(color.new(#ff1744, 0),   "Bearish",     group=grp_col)
c_neut     = input.color(color.new(#ffd600, 0),   "Neutral/MMM", group=grp_col)
c_vl       = input.color(color.new(#ff9800, 0),   "Vector Level",group=grp_col)
c_asia     = input.color(color.new(#78909c, 60),  "Asia Range",  group=grp_col)
c_bg       = input.color(color.new(#0d0d0d, 0),   "Background",  group=grp_col)

// ═══════════════════════════════════════════════════════════════
//  M1 — SESSION ENGINE  (EAT = UTC+3, no DST)
// ═══════════════════════════════════════════════════════════════
// All times in EAT hours (UTC+3). Pine timestamp() uses UTC.
// EAT hour n = UTC hour (n-3)
f_eat_hour() =>
    hour(time, "UTC+3")

f_eat_min() =>
    minute(time, "UTC+3")

// Returns true when EAT time is within [h_start:m_start, h_end:m_end)
f_in_session(int h_start, int m_start, int h_end, int m_end) =>
    eat_h = f_eat_hour()
    eat_m = f_eat_min()
    total_start = h_start * 60 + m_start
    total_end   = h_end   * 60 + m_end
    total_now   = eat_h   * 60 + eat_m
    total_now >= total_start and total_now < total_end

// Session IDs:  0=Asia  1=Frankfurt  2=London  3=NY Open  4=NY Trap  5=Ldn Close
// EAT windows:
//   Asia       03:00 – 10:00
//   Frankfurt  10:00 – 11:00
//   London     11:00 – 12:00  (open hour; broader London 11–20)
//   NY Open    16:00 – 17:00
//   NY Trap    17:00 – 18:00
//   Ldn Close  20:00 – 21:00
var int m1_session_id    = 0
var bool m1_is_mmm       = false
var bool m1_is_ny_trap   = false
var bool m1_is_ldn_close = false
var bool m1_is_frankfurt = false

// Broad London (for context) = 11:00–20:00 EAT
m1_broad_london = f_in_session(11, 0, 20, 0)
m1_asia_window  = f_in_session( 3, 0, 10, 0)
m1_fft_window   = f_in_session(10, 0, 11, 0)
m1_ldn_open     = f_in_session(11, 0, 12, 0)
m1_ny_open      = f_in_session(16, 0, 17, 0)
m1_ny_trap_w    = f_in_session(17, 0, 18, 0)
m1_ldn_close_w  = f_in_session(20, 0, 21, 0)

// Resolve session ID (priority order)
m1_session_id :=
    m1_asia_window  ? 0 :
    m1_fft_window   ? 1 :
    m1_ldn_open     ? 2 :
    m1_ny_open      ? 3 :
    m1_ny_trap_w    ? 4 :
    m1_ldn_close_w  ? 5 : na

m1_is_frankfurt = m1_fft_window
m1_is_ny_trap   = m1_ny_trap_w
m1_is_ldn_close = m1_ldn_close_w

// MMM windows: +30m and +1.5h after London open (11:30, 12:30 EAT)
//              +30m and +1.5h after NY open    (16:30, 17:30 EAT)
// tolerance: ±30 bars (on the active TF)
f_mmm_window(int h, int m) =>
    eat_h    = f_eat_hour()
    eat_m    = f_eat_min()
    total_now   = eat_h * 60 + eat_m
    total_center= h     * 60 + m
    math.abs(total_now - total_center) <= 30

m1_is_mmm :=
    f_mmm_window(11, 30) or f_mmm_window(12, 30) or
    f_mmm_window(16, 30) or f_mmm_window(17, 30)

// Session separators
var line ln_ldn_open = na
var line ln_ny_open  = na

if m1_ldn_open and not m1_ldn_open[1]
    ln_ldn_open := line.new(bar_index, low * 0.9999, bar_index, high * 1.0001,
         color=color.new(#00bcd4, 0), width=2, style=line.style_dashed, extend=line.extend.both)

if m1_ny_open and not m1_ny_open[1]
    ln_ny_open := line.new(bar_index, low * 0.9999, bar_index, high * 1.0001,
         color=color.new(#ce93d8, 0), width=2, style=line.style_dashed, extend=line.extend.both)

// MMM highlight background
bgcolor(m1_is_mmm and i_show_mmm ? color.new(c_neut, 88) : na, title="MMM Window")

// ═══════════════════════════════════════════════════════════════
//  M2 — ASIA RANGE ANALYZER
// ═══════════════════════════════════════════════════════════════
var float m2_asia_high       = na
var float m2_asia_low        = na
var float m2_asia_mid        = na
var float m2_asia_range_pips = na
var int   m2_asia_class      = na  // 0–6

var float _asia_h_track = na
var float _asia_l_track = na
var bool  _asia_locked  = false   // locked once Frankfurt opens

// Build Asia range bar-by-bar
if m1_asia_window
    _asia_h_track := na(_asia_h_track) ? high : math.max(_asia_h_track, high)
    _asia_l_track := na(_asia_l_track) ? low  : math.min(_asia_l_track, low)
    _asia_locked  := false

// At Frankfurt open — finalise Asia range and classify
if m1_fft_window and not m1_fft_window[1] and not na(_asia_h_track)
    m2_asia_high := _asia_h_track
    m2_asia_low  := _asia_l_track
    m2_asia_mid  := (_asia_h_track + _asia_l_track) / 2
    pips = (_asia_h_track - _asia_l_track) / syminfo.mintick / 10
    m2_asia_range_pips := pips
    _asia_locked := true

    // Classification logic (PDF pp 1–9 Case Studies)
    // 0=AWS  1=High/Low  2=Continuation  3=Midline  4=Impulsive  5=BuildUp  6=Rangebound
    // Impulsive = range > 40 pips
    // For classification we also check if price crossed the mid (whipsaw)
    crossed_high = high > _asia_h_track or close > _asia_h_track
    crossed_low  = low  < _asia_l_track or close < _asia_l_track

    m2_asia_class :=
        (crossed_high and crossed_low) ? 0 :   // AWS — both sides swept
        (crossed_high or crossed_low)  ? 1 :   // High/Low — one side
        pips > 40 and (crossed_high or crossed_low) ? 2 :  // Continuation (impulsive, mitigates HV)
        math.abs(close - m2_asia_mid) < (pips * syminfo.mintick * 10 * 0.1) ? 3 :  // Midline
        pips > 40 ? 4 :                         // Impulsive range (creates continuation OB)
        pips < 40 ? 5 : 6                       // Build-up or Rangebound

// Reset at start of new Asia session
if m1_asia_window and not m1_asia_window[1]
    _asia_h_track := na
    _asia_l_track := na
    _asia_locked  := false

// Asia range box visual
var box asia_box  = na
var line asia_mid = na

if m1_fft_window and not m1_fft_window[1] and not na(m2_asia_high) and i_show_sess
    box.delete(asia_box)
    line.delete(asia_mid)
    asia_box := box.new(bar_index - 1, m2_asia_high, bar_index + 200, m2_asia_low,
         border_color=c_asia, bgcolor=color.new(c_asia, 85), border_width=1)
    asia_mid := line.new(bar_index - 1, m2_asia_mid, bar_index + 200, m2_asia_mid,
         color=color.new(#b0bec5, 50), style=line.style_dashed, width=1)

// ═══════════════════════════════════════════════════════════════
//  M3 — DAILY CYCLE CLASSIFIER  (PDF pp 10–21)
// ═══════════════════════════════════════════════════════════════
// HTF data for bias
htf_close = request.security(syminfo.tickerid, i_htf, close,
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htf_high  = request.security(syminfo.tickerid, i_htf, high,
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htf_low   = request.security(syminfo.tickerid, i_htf, low,
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

daily_close = request.security(syminfo.tickerid, "D", close,
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
daily_high  = request.security(syminfo.tickerid, "D", high,
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
daily_low   = request.security(syminfo.tickerid, "D", low,
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// Simple momentum gauge: compare recent HTF closes
htf_momentum_bull = htf_close > htf_close[3] and htf_close[3] > htf_close[6]
htf_momentum_bear = htf_close < htf_close[3] and htf_close[3] < htf_close[6]
htf_ranging       = not htf_momentum_bull and not htf_momentum_bear

// Manual bias override
f_bias_bull() =>
    i_bias == "Bullish" or (i_bias == "Auto" and htf_momentum_bull)
f_bias_bear() =>
    i_bias == "Bearish" or (i_bias == "Auto" and htf_momentum_bear)
f_bias_range() =>
    i_bias == "Ranging" or (i_bias == "Auto" and htf_ranging)

// Daily cycle type (0–3)
// 0=DowntrendRun  1=SlightDowntrend  2=WithinRange  3=TrendReversal
var int   m3_cycle_type        = 2
var int   m3_daily_variant     = 0   // 0=BuildUpManipCont 1=BreakRetest 2=AsiaWhipsaw
var bool  m3_counter_trend_ok  = true
var int   m3_week_phase        = 0   // 0=Mon/fake 1=TueThuReal 2=FriAccum
var int   m3_movement_strength = 1   // 0=strong 1=medium 2=weak

// Week phase based on day of week
eat_dow = dayofweek(time, "UTC+3")
m3_week_phase :=
    eat_dow == dayofweek.monday   ? 0 :
    eat_dow == dayofweek.friday   ? 2 : 1

// Classify cycle from HTF momentum + Asia class
if barstate.isconfirmed
    // Impulsive Asia with strong HTF momentum → downtrend/uptrend run
    asia_impulsive = not na(m2_asia_class) and (m2_asia_class == 2 or m2_asia_class == 4)

    if f_bias_bear() and htf_momentum_bear
        m3_cycle_type := asia_impulsive ? 0 : 1
        m3_counter_trend_ok := m3_cycle_type == 1
        m3_movement_strength := m3_cycle_type == 0 ? 0 : 1
    else if f_bias_bull() and htf_momentum_bull
        m3_cycle_type := asia_impulsive ? 0 : 1
        m3_counter_trend_ok := m3_cycle_type == 1
        m3_movement_strength := m3_cycle_type == 0 ? 0 : 1
    else if f_bias_range()
        m3_cycle_type := 2
        m3_counter_trend_ok := true
        m3_movement_strength := 2
    else
        m3_cycle_type := 3   // trend reversal condition
        m3_counter_trend_ok := false
        m3_movement_strength := 0

    // Daily variant from Asia class (PDF pp 10–13)
    m3_daily_variant :=
        not na(m2_asia_class) and m2_asia_class == 0 ? 2 :   // AWS → AsiaWhipsaw
        not na(m2_asia_class) and m2_asia_class == 1 ? 1 :   // High/Low → BreakRetest
        0                                                       // Default → BuildUpManipCont

// ═══════════════════════════════════════════════════════════════
//  M4 — STRUCTURE ENGINE  (PDF pp 10–21, 43–49)
// ═══════════════════════════════════════════════════════════════
// Swing high/low detection
f_swing_high(int len) =>
    ta.pivothigh(high, len, len)

f_swing_low(int len) =>
    ta.pivotlow(low, len, len)

swing_h = f_swing_high(i_swing_len)
swing_l = f_swing_low(i_swing_len)

// Track last two confirmed swing highs and lows
var float sh1 = na  // most recent swing high
var float sh2 = na  // previous swing high
var float sl1 = na
var float sl2 = na
var int   sh1_idx = na
var int   sl1_idx = na

if not na(swing_h)
    sh2 := sh1
    sh1 := swing_h
    sh1_idx := bar_index - i_swing_len

if not na(swing_l)
    sl2 := sl1
    sl1 := swing_l
    sl1_idx := bar_index - i_swing_len

// BoS: price closes beyond last swing high/low
var bool m4_bos_bull   = false
var bool m4_bos_bear   = false
var float m4_bos_level = na

m4_bos_bull := not na(sh1) and close[1] < sh1 and close > sh1
m4_bos_bear := not na(sl1) and close[1] > sl1 and close < sl1

if m4_bos_bull
    m4_bos_level := sh1
if m4_bos_bear
    m4_bos_level := sl1

// ChoCh: sweep of swing extreme + BoS in opposite direction
// A valid ChoCh MUST have inducement above/below it (checked in M6)
var bool  m4_choch_candidate = false
var bool  m4_choch_valid     = false   // confirmed by M6
var bool  m4_choch_smt       = false   // tap on valid supply/demand BEFORE ChoCh = SMT
var float m4_choch_level     = na
var int   m4_choch_dir       = 0       // 1=bull ChoCh, -1=bear ChoCh

// Detect ChoCh candidate: wick swept previous swing, then close broke prior BoS direction
if not na(sh1) and not na(sl1)
    // Bearish ChoCh candidate: high swept sh1 as wick, then close < sl1
    if high > sh1 and close < sh1 and m4_bos_bear
        m4_choch_candidate := true
        m4_choch_dir       := -1
        m4_choch_level     := sl1
    // Bullish ChoCh candidate: low swept sl1 as wick, then close > sh1
    else if low < sl1 and close > sl1 and m4_bos_bull
        m4_choch_candidate := true
        m4_choch_dir       := 1
        m4_choch_level     := sh1
    else
        m4_choch_candidate := false

// LPOD/S tracking — last swing before which structure still holds
var float m4_lpod = na  // last point of demand (buy zone floor)
var float m4_lpos = na  // last point of supply (sell zone ceiling)

if m4_bos_bull and not na(sl1)
    m4_lpod := sl1
if m4_bos_bear and not na(sh1)
    m4_lpos := sh1

// S/R Flip: broken support → resistance (Phase 1 candidate zones)
var float m4_sr_flip_level = na
if m4_bos_bear and not na(sl1)
    m4_sr_flip_level := sl1  // old support now resistance
if m4_bos_bull and not na(sh1)
    m4_sr_flip_level := sh1  // old resistance now support

// MSS pending: when ChoCh candidate exists and we haven't confirmed yet
var bool m4_mss_pending = false
m4_mss_pending := m4_choch_candidate and not m4_choch_valid

// Corrective leg detection: all demand (if selling) / supply (if buying) in chain mitigated
// Simplified: if LPOD/S has been swept (price moved through it)
var bool m4_corrective_leg = false
if not na(m4_lpod) and close < m4_lpod and f_bias_bear()
    m4_corrective_leg := true
else if not na(m4_lpos) and close > m4_lpos and f_bias_bull()
    m4_corrective_leg := true
else
    m4_corrective_leg := false

// Visual: BoS labels
if m4_bos_bull and barstate.isconfirmed
    label.new(bar_index, low, "BoS ▲", style=label.style_label_up,
         color=color.new(c_bull, 70), textcolor=c_bull, size=size.tiny)
if m4_bos_bear and barstate.isconfirmed
    label.new(bar_index, high, "BoS ▼", style=label.style_label_down,
         color=color.new(c_bear, 70), textcolor=c_bear, size=size.tiny)
if m4_choch_candidate and barstate.isconfirmed
    lbl_txt = m4_choch_dir == 1 ? "ChoCh?" : "ChoCh?"
    label.new(bar_index, m4_choch_dir == 1 ? low : high, lbl_txt,
         style=m4_choch_dir == 1 ? label.style_label_up : label.style_label_down,
         color=color.new(c_neut, 70), textcolor=c_neut, size=size.tiny)

// ═══════════════════════════════════════════════════════════════
//  M5 — ORDERBLOCK VALIDATOR  (PDF pp 22–25)
// ═══════════════════════════════════════════════════════════════
// 3-Rule Gate (ALL 3 required, binary):
//   Rule 1: Has Imbalance   — gap between candle body and next candle (FVG/IMB on 1m)
//   Rule 2: Be Impulsive    — large body relative to recent ATR
//   Rule 3: Creates Inducement — swing high/low exists above/below zone

f_has_imbalance(int idx) =>
    // FVG: gap between high[idx+1] and low[idx-1] (3-bar check)
    idx >= 1 and idx <= bar_index - 1 ?
        high[idx + 1] < low[idx - 1] or low[idx + 1] > high[idx - 1] : false

f_is_impulsive(int idx) =>
    body = math.abs(close[idx] - open[idx])
    atr  = ta.atr(14)
    body > atr * 0.7

f_has_inducement_above(float zone_high) =>
    // At least one swing high in the last i_ob_len bars above zone_high
    found = false
    for i = 1 to i_ob_len
        if high[i] > zone_high
            found := true
            break
    found

f_has_inducement_below(float zone_low) =>
    found = false
    for i = 1 to i_ob_len
        if low[i] < zone_low
            found := true
            break
    found

// OB detection — scan lookback for valid engulfed OBs
// Returns [ob_valid, ob_type, ob_high, ob_low] for most recent candidate
var bool  m5_ob_valid      = false
var int   m5_ob_type       = na   // 0–4
var float m5_ob_true_high  = na
var float m5_ob_true_low   = na
var string m5_ob_tf        = timeframe.period
var bool  m5_slight_mit    = false

// Engulfed OB: candle before large move in opposite direction
// Bearish OB (supply): bullish candle before big bearish move
// Bullish OB (demand): bearish candle before big bull move
f_detect_ob(bool bull_seeking) =>
    ob_found = false
    ob_type_out = na
    ob_h = na
    ob_l = na
    for i = 1 to i_ob_len
        // The candidate OB candle
        cand_bull  = close[i] > open[i]
        cand_bear  = close[i] < open[i]
        body_size  = math.abs(close[i] - open[i])
        // Check if followed by impulse in opposite direction
        next_bull  = i > 1 ? close[i - 1] > open[i - 1] : false
        next_bear  = i > 1 ? close[i - 1] < open[i - 1] : false
        // Looking for demand (bullish) OB: bearish candle before big bull move
        if bull_seeking and cand_bear and next_bull
            // 3-rule gate
            r1 = f_has_imbalance(i)
            r2 = f_is_impulsive(i)
            r3 = f_has_inducement_below(low[i])
            if r1 and r2 and r3
                ob_found    := true
                ob_type_out := 0  // Engulfed OB
                ob_h        := open[i]
                ob_l        := low[i]
                break
            // Wick/Hammer OB: large lower wick
            wick_low  = close[i] - low[i]
            wick_bull = wick_low > body_size * 2
            if wick_bull and r1 and r3
                ob_found    := true
                ob_type_out := 2  // Wick OB
                ob_h        := open[i]
                ob_l        := low[i] + wick_low * 0.5
                break
        // Looking for supply (bearish) OB
        if not bull_seeking and cand_bull and next_bear
            r1 = f_has_imbalance(i)
            r2 = f_is_impulsive(i)
            r3 = f_has_inducement_above(high[i])
            if r1 and r2 and r3
                ob_found    := true
                ob_type_out := 0
                ob_h        := high[i]
                ob_l        := open[i]
                break
            wick_high = high[i] - close[i]
            wick_bear = wick_high > body_size * 2
            if wick_bear and r1 and r3
                ob_found    := true
                ob_type_out := 2
                ob_h        := high[i] - wick_high * 0.5
                ob_l        := open[i]
                break
    [ob_found, ob_type_out, ob_h, ob_l]

// Run OB detection based on current bias
is_bull_bias = f_bias_bull()
is_bear_bias = f_bias_bear()

[ob_v, ob_t, ob_h, ob_l] = f_detect_ob(is_bull_bias)

if barstate.isconfirmed
    m5_ob_valid     := ob_v
    m5_ob_type      := ob_t
    m5_ob_true_high := ob_h
    m5_ob_true_low  := ob_l
    m5_ob_tf        := timeframe.period

    // Slight mitigation: price entered zone but didn't reach high-volume candle body
    if m5_ob_valid and not na(m5_ob_true_high)
        in_zone = is_bull_bias ? (low <= m5_ob_true_high and low >= m5_ob_true_low) :
                                 (high >= m5_ob_true_low  and high <= m5_ob_true_high)
        reached_body = is_bull_bias ? close >= m5_ob_true_low : close <= m5_ob_true_high
        m5_slight_mit := in_zone and not reached_body

// Complex SMT OB: clean OB but no inducement above/below → warning flag
var bool m5_is_smt_ob = false
if m5_ob_valid
    has_ind = is_bull_bias ? f_has_inducement_below(m5_ob_true_low) :
                             f_has_inducement_above(m5_ob_true_high)
    m5_is_smt_ob := not has_ind
    if m5_is_smt_ob
        m5_ob_type := 3  // Complex/SMT OB

// Draw OB zone boxes
var box ob_box = na
if m5_ob_valid and barstate.isconfirmed and not na(m5_ob_true_high)
    box.delete(ob_box)
    box_col = is_bull_bias ? color.new(c_bull, 80) : color.new(c_bear, 80)
    box_brd = is_bull_bias ? c_bull : c_bear
    ob_box := box.new(bar_index - i_ob_len, m5_ob_true_high, bar_index + 50,
         m5_ob_true_low, border_color=box_brd, bgcolor=box_col, border_width=1)
    ob_type_str = m5_ob_type == 0 ? "ENG" : m5_ob_type == 1 ? "IMB" :
                  m5_ob_type == 2 ? "WCK" : m5_ob_type == 3 ? "SMT⚠" : "PH1"
    label.new(bar_index - i_ob_len, m5_ob_true_high,
         (is_bull_bias ? "DEMAND " : "SUPPLY ") + ob_type_str,
         style=label.style_label_right, color=color.new(box_brd, 70),
         textcolor=color.white, size=size.tiny)

// ═══════════════════════════════════════════════════════════════
//  M6 — INDUCEMENT LAYER  (PDF pp 26–37)
// ═══════════════════════════════════════════════════════════════
// Phase 1: last level of price before imbalance of valid OB; detached supply/demand chain

var float m6_phase1_level  = na
var int   m6_phase1_type   = na   // 0=minor 1=medium 2=major
var float m6_phase2_level  = na
var int   m6_phase2_type   = na   // 0–3
var int   m6_inducement_count = 0
var int   m6_amd_phase     = 0    // 0=accum 1=manip 2=distrib
var int   m6_ipb_vs_rev    = 2    // 0=IPB 1=Reversal 2=undetermined
var float m6_evil_candle   = na   // price of the evil candle extreme
var bool  m6_phase1_swept  = false
var bool  m6_phase2_swept  = false

// Phase 1 type from inducement size (PDF p 5)
// Minor: M1/M5 BoS — structural break that "does nothing to the left"
// Medium: M5/M15 BoS — does something to the left
// Major: M15/H1 BoS
f_phase1_type() =>
    // Use timeframe and lookback to infer scale of inducement
    // On 1m: minor; on 5m: medium; on 15m+: major
    tf_mins = timeframe.in_seconds() / 60
    tf_mins <= 1 ? 0 : tf_mins <= 5 ? 1 : 2

// Identify Phase 1 level = extreme of the inducement candle before OB imbalance
// This is the "evil candle" level — first candle that misses the high-volume OB
if m5_ob_valid and barstate.isconfirmed
    // Phase 1 = the swing extreme nearest to (but outside) the OB zone
    if is_bull_bias and not na(m5_ob_true_low)
        // Looking for supply below the demand zone that will be swept
        // Phase 1 is the last swing LOW below the OB before imbalance
        for i = 1 to i_ob_len
            if low[i] < m5_ob_true_low
                m6_phase1_level := low[i]
                m6_evil_candle  := low[i]
                break
    else if is_bear_bias and not na(m5_ob_true_high)
        for i = 1 to i_ob_len
            if high[i] > m5_ob_true_high
                m6_phase1_level := high[i]
                m6_evil_candle  := high[i]
                break
    m6_phase1_type := f_phase1_type()

// Track Phase 1 swept: current price sweeps Phase 1 level
if not na(m6_phase1_level)
    m6_phase1_swept :=
        is_bull_bias ? low <= m6_phase1_level :
                       high >= m6_phase1_level

// Phase 2 detection: after Phase 1 is swept
// Determine Phase 2 sub-type from market structure post-sweep
if m6_phase1_swept and not m6_phase2_swept and barstate.isconfirmed
    // ChoCh inducement (Type 0) — detected via M4 ChoCh candidate after OB tap
    if m4_choch_candidate
        m6_phase2_type  := 0
        m6_phase2_level := m4_choch_level
        m6_choch_valid  = true  // confirm M4 ChoCh — inducement exists
    // Resting Liquidity / SMT (Type 1) — price formed small accumulation near OB
    else if m5_slight_mit
        m6_phase2_type  := 1
        m6_phase2_level := is_bull_bias ? m5_ob_true_low : m5_ob_true_high
    // Two Phase 1s (Type 2) — inducement count ≥ 2
    else if m6_inducement_count >= 2
        m6_phase2_type  := 2
        m6_phase2_level := m6_phase1_level
    // Second Miss (Type 3) — price missed refinement zone again after Phase 1
    else if m5_ob_valid and not na(m5_ob_true_high)
        near_zone = is_bull_bias ?
             (low <= m5_ob_true_high * 1.001 and close > m5_ob_true_high) :
             (high >= m5_ob_true_low  * 0.999 and close < m5_ob_true_low)
        if near_zone
            m6_phase2_type  := 3
            m6_phase2_level := is_bull_bias ? m5_ob_true_low : m5_ob_true_high
    else
        m6_phase2_type  := 0  // default to ChoCh
        m6_phase2_level := na

// Track Phase 2 swept
if not na(m6_phase2_level)
    m6_phase2_swept :=
        is_bull_bias ? low <= m6_phase2_level :
                       high >= m6_phase2_level

// Inducement count — increment each time a Phase 1 or Phase 2 gets swept
if m6_phase1_swept and not m6_phase1_swept[1]
    m6_inducement_count := m6_inducement_count + 1
if m6_phase2_swept and not m6_phase2_swept[1]
    m6_inducement_count := m6_inducement_count + 1

// AMD Phase (Power of 3 integration)
// Accumulation = Phase 1 not yet swept
// Manipulation = Phase 1 swept, heading into OB
// Distribution  = Phase 2 swept, MSS confirmed
m6_amd_phase :=
    not m6_phase1_swept ? 0 :
    m6_phase1_swept and not m6_phase2_swept ? 1 : 2

// IPB vs Reversal determination
// Reversal: Phase 1 swept + structure of sweep leg BROKEN → MSS
// IPB: Phase 1 swept + structure RESPECTED → continuation
if m6_phase1_swept
    if m4_bos_bull and is_bull_bias
        m6_ipb_vs_rev := 1   // Reversal confirmed
    else if m4_bos_bear and is_bear_bias
        m6_ipb_vs_rev := 1
    else if m4_choch_candidate
        m6_ipb_vs_rev := 2   // undetermined — ChoCh candidate pending
    else
        m6_ipb_vs_rev := 0   // IPB continuation

// Evil Candle marker
if not na(m6_evil_candle) and m6_phase1_swept and not m6_phase1_swept[1]
    label.new(bar_index, m6_evil_candle, "●",
         style=label.style_circle,
         color=color.new(c_neut, 0),
         textcolor=color.new(c_neut, 0), size=size.tiny)

// Phase 1 line — dashed, labeled x1
var line ph1_line = na
if m6_phase1_swept and not m6_phase1_swept[1] and not na(m6_phase1_level)
    line.delete(ph1_line)
    ph1_col = is_bull_bias ? color.new(c_bull, 20) : color.new(c_bear, 20)
    ph1_line := line.new(bar_index - 5, m6_phase1_level, bar_index + 80, m6_phase1_level,
         color=ph1_col, style=line.style_dashed, width=2)
    label.new(bar_index + 80, m6_phase1_level, "x1",
         style=label.style_label_left, color=color.new(ph1_col, 60),
         textcolor=ph1_col, size=size.tiny)

// Phase 2 line — solid, labeled x2
var line ph2_line = na
if m6_phase2_swept and not m6_phase2_swept[1] and not na(m6_phase2_level)
    line.delete(ph2_line)
    ph2_col = is_bull_bias ? c_bull : c_bear
    ph2_line := line.new(bar_index - 5, m6_phase2_level, bar_index + 80, m6_phase2_level,
         color=ph2_col, style=line.style_solid, width=2)
    label.new(bar_index + 80, m6_phase2_level, "x2",
         style=label.style_label_left, color=color.new(ph2_col, 60),
         textcolor=ph2_col, size=size.tiny)

// ═══════════════════════════════════════════════════════════════
//  M7 — VECTOR LEVEL TRACKER  (PDF pp 33–34)
// ═══════════════════════════════════════════════════════════════
// Vector Level = valid zone before push into OB; responsible for Phase 1 sweep
// but FAILS to create new low (buying) / high (selling)

var float m7_vector_level         = na
var bool  m7_mss_valid            = false
var bool  m7_manipulation_confirmed = false
var bool  m7_reversal_confirmed   = false

// The Vector Level is the OB-like zone immediately before Phase 1 sweep
// It must follow 3 OB rules (especially imbalance) and is impulsive (vector candle)
// Identify: the candle that created the Phase 1 sweep is the Vector Level origin
if m6_phase1_swept and not m6_phase1_swept[1] and m5_ob_valid
    // Vector Level = the last valid zone before Phase 1 was swept
    // Use the OB zone boundaries (refined) as the Vector Level
    m7_vector_level := is_bull_bias ? m5_ob_true_low : m5_ob_true_high

// MSS Validity Gate (PDF pp 33–34):
// VALID path 1: price mitigates Vector Level + creates Phase 2 reversal inducement
// VALID path 2: price breaks Vector Level + creates Phase 2 reversal inducement
// INVALID: price RESPECTS Vector Level → continuation (IPB), not reversal

if not na(m7_vector_level) and m6_phase2_swept and barstate.isconfirmed
    // Check interaction with Vector Level
    vl_mitigated = is_bull_bias ?
         (low  <= m7_vector_level and close > m7_vector_level) :
         (high >= m7_vector_level and close < m7_vector_level)
    vl_broken = is_bull_bias ?
         close > m7_vector_level :
         close < m7_vector_level

    if (vl_mitigated or vl_broken) and m6_phase2_swept
        m7_mss_valid             := true
        m7_manipulation_confirmed := true
        m7_reversal_confirmed    := m6_amd_phase == 2
    else
        // Price respected VL → IPB continuation, not reversal
        m7_mss_valid             := false
        m7_manipulation_confirmed := false
        m7_reversal_confirmed    := false
        // Force IPB classification
        m6_ipb_vs_rev := 0

// Also confirm M4 ChoCh validity here: ChoCh is valid only when inducement exists
if m4_choch_candidate and not na(m6_phase1_level)
    m4_choch_valid := true
else if m4_choch_candidate
    m4_choch_smt := true   // No inducement → SMT, not valid ChoCh

// Vector Level visual — orange dashed line labeled "VL"
var line vl_line = na
if not na(m7_vector_level) and (m7_mss_valid != m7_mss_valid[1] or bar_index == 1)
    line.delete(vl_line)
    vl_line := line.new(bar_index - 10, m7_vector_level, bar_index + 60, m7_vector_level,
         color=c_vl, style=line.style_dashed, width=2)
    label.new(bar_index + 60, m7_vector_level, "VL",
         style=label.style_label_left, color=color.new(c_vl, 60),
         textcolor=c_vl, size=size.tiny)

if m7_mss_valid and not m7_mss_valid[1]
    label.new(bar_index, is_bull_bias ? low : high, "MSS ✓",
         style=is_bull_bias ? label.style_label_up : label.style_label_down,
         color=color.new(c_bull, 50), textcolor=c_bull, size=size.small)

// ═══════════════════════════════════════════════════════════════
//  MODULE STATE DASHBOARD (top-right corner)
// ═══════════════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 14,
     bgcolor=color.new(#0a0a0a, 10), border_width=1, border_color=color.new(#333333, 0))

if barstate.islast
    // Header
    table.cell(dash, 0, 0, "PIE-v1 CORE", text_color=c_neut,
         bgcolor=color.new(#1a1a2e, 0), text_size=size.small)
    table.cell(dash, 1, 0, "ADI / EAT", text_color=color.gray,
         bgcolor=color.new(#1a1a2e, 0), text_size=size.small)

    // M1
    sess_names = array.from("Asia", "Frankfurt", "London", "NY Open", "NY Trap", "Ldn Close")
    sess_str   = not na(m1_session_id) ? array.get(sess_names, m1_session_id) : "Off-Hours"
    table.cell(dash, 0, 1, "M1 Session", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 1, sess_str + (m1_is_mmm ? " ⚡MMM" : ""),
         text_color=m1_is_mmm ? c_neut : color.white, text_size=size.tiny)

    // M2
    asia_class_names = array.from("AWS","High/Low","Continuation","Midline","Impulsive","BuildUp","Rangebound")
    asia_cls_str = not na(m2_asia_class) ? array.get(asia_class_names, m2_asia_class) : "Pending"
    table.cell(dash, 0, 2, "M2 Asia", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 2, asia_cls_str + " | " + (not na(m2_asia_range_pips) ? str.tostring(math.round(m2_asia_range_pips)) + "p" : "?"),
         text_color=color.white, text_size=size.tiny)

    // M3
    cycle_names = array.from("DownRun","SlightDn","Range","Reversal")
    variant_names = array.from("BldUpMC","BrkRetest","AsiaWS")
    cycle_str = not na(m3_cycle_type) ? array.get(cycle_names, m3_cycle_type) : "?"
    variant_str = array.get(variant_names, m3_daily_variant)
    table.cell(dash, 0, 3, "M3 Cycle", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 3, cycle_str + " | " + variant_str + (m3_counter_trend_ok ? " CT✓" : ""),
         text_color=color.white, text_size=size.tiny)

    // M4
    struct_str = m4_bos_bull ? "BoS ▲" : m4_bos_bear ? "BoS ▼" :
                 m4_choch_valid ? "ChoCh✓" : m4_mss_pending ? "MSS⏳" : "Watching"
    table.cell(dash, 0, 4, "M4 Structure", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 4, struct_str + (m4_corrective_leg ? " CorrLeg" : ""),
         text_color=m4_choch_valid ? c_bull : color.white, text_size=size.tiny)

    // M5
    ob_names = array.from("Engulfed","Imbalance","Wick","SMT⚠","Phase1Rx")
    ob_str = m5_ob_valid and not na(m5_ob_type) ? array.get(ob_names, m5_ob_type) : "None"
    table.cell(dash, 0, 5, "M5 OB", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 5, ob_str + (m5_slight_mit ? " SlightMit" : ""),
         text_color=m5_ob_valid ? (is_bull_bias ? c_bull : c_bear) : color.gray, text_size=size.tiny)

    // M6
    ph1_names = array.from("Minor","Medium","Major")
    ph2_names = array.from("ChoCh","RestLiq","2xPh1","2ndMiss")
    ph1_str = not na(m6_phase1_type) ? array.get(ph1_names, m6_phase1_type) : "?"
    ph2_str = not na(m6_phase2_type) ? array.get(ph2_names, m6_phase2_type) : "?"
    amd_str = m6_amd_phase == 0 ? "Accum" : m6_amd_phase == 1 ? "Manip" : "Distrib"
    table.cell(dash, 0, 6, "M6 Inducement", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 6, "Ph1:" + ph1_str + " Ph2:" + ph2_str + " AMD:" + amd_str + " #" + str.tostring(m6_inducement_count),
         text_color=m6_phase2_swept ? c_bull : m6_phase1_swept ? c_neut : color.gray, text_size=size.tiny)

    // M7
    mss_str = m7_mss_valid ? "VALID ✓" : m4_mss_pending ? "Pending..." : "Invalid"
    table.cell(dash, 0, 7, "M7 Vector/MSS", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 7, mss_str + (m7_manipulation_confirmed ? " Manip✓" : "") + (m7_reversal_confirmed ? " Rev✓" : ""),
         text_color=m7_mss_valid ? c_bull : m4_mss_pending ? c_neut : color.red, text_size=size.tiny)

    // OB zone info
    table.cell(dash, 0, 8, "OB Zone", text_color=color.silver, text_size=size.tiny)
    ob_zone_str = not na(m5_ob_true_high) ?
         str.tostring(m5_ob_true_high, "#.#####") + " / " + str.tostring(m5_ob_true_low, "#.#####") : "None"
    table.cell(dash, 1, 8, ob_zone_str, text_color=color.white, text_size=size.tiny)

    // Phase levels
    table.cell(dash, 0, 9, "Ph1 / Ph2", text_color=color.silver, text_size=size.tiny)
    ph_str = (not na(m6_phase1_level) ? str.tostring(m6_phase1_level, "#.#####") : "?") + " / " +
             (not na(m6_phase2_level) ? str.tostring(m6_phase2_level, "#.#####") : "?")
    table.cell(dash, 1, 9, ph_str, text_color=color.white, text_size=size.tiny)

    // Vector Level
    table.cell(dash, 0, 10, "Vector Level", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 10, not na(m7_vector_level) ? str.tostring(m7_vector_level, "#.#####") : "None",
         text_color=c_vl, text_size=size.tiny)

    // LPOD/S
    table.cell(dash, 0, 11, "LPOD / LPOS", text_color=color.silver, text_size=size.tiny)
    lpods_str = (not na(m4_lpod) ? str.tostring(m4_lpod, "#.#####") : "?") + " / " +
                (not na(m4_lpos) ? str.tostring(m4_lpos, "#.#####") : "?")
    table.cell(dash, 1, 11, lpods_str, text_color=color.white, text_size=size.tiny)

    // Week phase
    week_phase_str = m3_week_phase == 0 ? "Mon/Fake" : m3_week_phase == 1 ? "Tue-Thu/Real" : "Fri/Accum"
    strength_str   = m3_movement_strength == 0 ? "Strong" : m3_movement_strength == 1 ? "Medium" : "Weak"
    table.cell(dash, 0, 12, "Week / Strength", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 12, week_phase_str + " | " + strength_str,
         text_color=color.white, text_size=size.tiny)

    // IPB vs Reversal
    ipb_rev_str = m6_ipb_vs_rev == 0 ? "IPB (Continuation)" : m6_ipb_vs_rev == 1 ? "REVERSAL" : "Undetermined"
    table.cell(dash, 0, 13, "Signal Type", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 13, ipb_rev_str,
         text_color=m6_ipb_vs_rev == 1 ? c_bull : m6_ipb_vs_rev == 0 ? c_neut : color.gray,
         text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
//  EXPORTED VALUES via plot() for PIE_v1_SIGNALS.pine
//  (Pine Script doesn't have cross-script variables — these plots
//   are the data bridge. In PIE_v1_SIGNALS, use request.security()
//   pointing to this script's ticker to read them.)
// ═══════════════════════════════════════════════════════════════
plot(m1_session_id,        title="[EXP] session_id",        display=display.data_window)
plot(m1_is_mmm ? 1 : 0,   title="[EXP] is_mmm",            display=display.data_window)
plot(m2_asia_class,        title="[EXP] asia_class",         display=display.data_window)
plot(m2_asia_range_pips,   title="[EXP] asia_range_pips",    display=display.data_window)
plot(m3_cycle_type,        title="[EXP] cycle_type",         display=display.data_window)
plot(m3_counter_trend_ok ? 1 : 0, title="[EXP] counter_trend_ok", display=display.data_window)
plot(m4_bos_bull ? 1 : 0, title="[EXP] bos_bull",           display=display.data_window)
plot(m4_bos_bear ? 1 : 0, title="[EXP] bos_bear",           display=display.data_window)
plot(m4_choch_valid ? 1 : 0, title="[EXP] choch_valid",     display=display.data_window)
plot(m4_corrective_leg ? 1 : 0, title="[EXP] corrective_leg", display=display.data_window)
plot(m4_lpod,              title="[EXP] lpod",               display=display.data_window)
plot(m4_lpos,              title="[EXP] lpos",               display=display.data_window)
plot(m5_ob_valid ? 1 : 0, title="[EXP] ob_valid",           display=display.data_window)
plot(m5_ob_type,           title="[EXP] ob_type",            display=display.data_window)
plot(m5_ob_true_high,      title="[EXP] ob_true_high",       display=display.data_window)
plot(m5_ob_true_low,       title="[EXP] ob_true_low",        display=display.data_window)
plot(m5_slight_mit ? 1 : 0, title="[EXP] slight_mitigation", display=display.data_window)
plot(m6_phase1_level,      title="[EXP] phase1_level",       display=display.data_window)
plot(m6_phase1_type,       title="[EXP] phase1_type",        display=display.data_window)
plot(m6_phase2_level,      title="[EXP] phase2_level",       display=display.data_window)
plot(m6_phase2_type,       title="[EXP] phase2_type",        display=display.data_window)
plot(m6_inducement_count,  title="[EXP] inducement_count",   display=display.data_window)
plot(m6_amd_phase,         title="[EXP] amd_phase",          display=display.data_window)
plot(m6_ipb_vs_rev,        title="[EXP] ipb_vs_reversal",    display=display.data_window)
plot(m7_vector_level,      title="[EXP] vector_level",       display=display.data_window)
plot(m7_mss_valid ? 1 : 0, title="[EXP] mss_valid",          display=display.data_window)
plot(m7_manipulation_confirmed ? 1 : 0, title="[EXP] manipulation_confirmed", display=display.data_window)
plot(m7_reversal_confirmed ? 1 : 0, title="[EXP] reversal_confirmed",         display=display.data_window)
